{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": ["db/**", "typed-router.d.ts"],
	"useTabs": true,
	"tabWidth": 4,
	"singleQuote": true,
	"semi": false,
	"insertFinalNewline": false,
	"singleAttributePerLine": true,
	"arrowParens": "avoid",
	"trailingComma": "none"
}